            {
              "name": "name",
              "value": "={{ $node[\"Execute Workflow Trigger\"].json.name }}"
            },
            {
              "name": "email",
              "value": "={{ $node[\"Execute Workflow Trigger\"].json.email }}"
            },
            {
              "name": "phone",
              "value": "={{ $node[\"Execute Workflow Trigger\"].json.phone }}"
            },
            {
              "name": "job_role",
              "value": "={{ $node[\"Execute Workflow Trigger\"].json.job_role }}"
            },
            {
              "name": "resume_text",
              "value": "={{ $node[\"Execute Workflow Trigger\"].json.resume_text }}"
            },
            {
              "name": "timestamp",
              "value": "={{ $node[\"Execute Workflow Trigger\"].json.timestamp }}"
            },
            {
              "name": "score",
              "value": "={{ JSON.parse($json.stdout).score }}"
            },
            {
              "name": "reason",
              "value": "={{ JSON.parse($json.stdout).reason }}"
            },
            {
              "name": "skills_matched",
              "value": "={{ JSON.stringify(JSON.parse($json.stdout).skills_matched) }}"
            },
            {
              "name": "missing_skills",
              "value": "={{ JSON.stringify(JSON.parse($json.stdout).missing_skills) }}"
            },
            {
              "name": "ats_score",
              "value": "={{ JSON.parse($json.stdout).ats_score }}"
            },
            {
              "name": "matched_keywords",
              "value": "={{ JSON.stringify(JSON.parse($json.stdout).matched_keywords) }}"
            },
            {
              "name": "missing_keywords",
              "value": "={{ JSON.stringify(JSON.parse($json.stdout).missing_keywords) }}"
            },
            {
              "name": "match_summary",
              "value": "={{ JSON.parse($json.stdout).match_summary }}"
            }
          ]
        },
        "options": {}
      },
      "id": "d8e3c6f1-cc91-4bc9-88aa-1224dcf5d1e2",
      "name": "Parse and Merge AI Results",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        640,
        280
      ]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ Number($json.score) }}",
