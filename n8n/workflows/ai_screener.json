            "ATS Score": "={{ $json.ats_score }}",
            "Matched Keywords": "={{ $json.matched_keywords }}",
            "Missing Keywords": "={{ $json.missing_keywords }}",
            "Match Summary": "={{ $json.match_summary }}",
            "Status": "={{ Number($json.score) >= 65 ? 'Shortlisted' : 'Rejected' }}",
            "Meeting Link": "={{ $json.meeting_link || '' }}",
            "Meet Link": "={{ $json.meet_link || '' }}"
